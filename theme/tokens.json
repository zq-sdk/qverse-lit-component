      "small": "2px",
      "round": "20px",
      "circle": "100%"
    },
    "font": {
      "family": "'Helvetica Neue', Helvetica, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', '微软雅黑', Arial, sans-serif",
      "sizeBase": "14px",
      "sizeSmall": "13px",
      "sizeLarge": "18px",
      "lineHeightPrimary": "24px"
    },
    "component": {
      "size": "32px",
      "sizeSmall": "24px",
      "sizeLarge": "40px"
    },
    "card": {
      "borderColor": "#e4e7ed",
      "borderRadius": "4px",
      "padding": "20px",
      "bgColor": "#ffffff"
    },
    "shadow": {
      "light": "0px 0px 12px rgba(0, 0, 0, 0.12)"
    },
    "transition": {
      "duration": "0.3s"
    }
