{
  "$comment": "设计令牌单一数据源。修改后执行: npm run generate-theme",
  "elementPlus": {
    "color": {
      "primary": "#409eff",
      "primaryLight3": "#79bbff",
      "primaryLight5": "#a0cfff",
      "primaryLight7": "#c6e2ff",
      "primaryLight8": "#d9ecff",
      "primaryLight9": "#ecf5ff",
      "primaryDark2": "#337ecc",
      "success": "#67c23a",
      "successLight3": "#95d475",
      "successLight5": "#b3e19d",
      "successDark2": "#529b2e",
      "warning": "#e6a23c",
      "danger": "#f56c6c",
      "dangerLight3": "#f89898",
      "dangerLight5": "#fab6b6",
      "dangerDark2": "#c45656",
      "info": "#909399",
      "textPrimary": "#303133",
      "textRegular": "#606266",
      "textSecondary": "#909399",
      "textPlaceholder": "#a8abb2",
      "border": "#dcdfe6",
      "borderLight": "#e4e7ed",
      "borderLighter": "#ebeef5",
      "fill": "#f0f2f5",
      "fillBlank": "#ffffff",
