{
  "name": "@qverse-ui/lit-components",
  "version": "1.0.11",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "description": "Lit Web Components（components/base + components/common）",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./base": {
      "types": "./dist/components/base/index.d.ts",
      "import": "./dist/components/base/index.js"
    },
    "./common": {
      "types": "./dist/components/common/index.d.ts",
      "import": "./dist/components/common/index.js"
    },
    "./theme.css": {
      "import": "./theme/generated/element-plus-vars.css",
      "default": "./theme/generated/element-plus-vars.css"
    }
  },
  "files": [
    "dist",
    "theme/tokens.json",
    "theme/generated"
  ],
  "scripts": {
    "generate-theme": "node scripts/generate-theme.mjs",
    "dev": "npm run generate-theme && vite build --watch",
    "build": "npm run generate-theme && vite build && tsc -p tsconfig.build.json",
    "prepare": "husky",
    "lint": "eslint \"**/*.{js,ts}\"",
    "release:major": "node scripts/release.js major",
    "release:minor": "node scripts/release.js minor",
    "release:patch": "node scripts/release.js patch",
    "release:tag": "node scripts/release.js tag"

  },
  "lint-staged": {
    "src/**/*.{ts,js}": "eslint --fix",
    "sample/src/**/*.{ts,js,vue}": "eslint --fix",
    "scripts/**/*.{js,mjs}": "eslint --fix",
    "vite.config.ts": "eslint --fix",
    "sample/vite.config.ts": "eslint --fix",
    "eslint.config.js": "eslint --fix",
    "commitlint.config.js": "eslint --fix"
  },
  "peerDependencies": {
    "element-plus": "^2.14.0",
    "lit": "^3.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^9.39.1",
    "@stylistic/eslint-plugin": "^5.6.1",
    "element-plus": "^2.14.0",
    "eslint": "^9.39.1",
    "eslint-plugin-vue": "^10.5.1",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "lit": "^3.2.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^6.0.7"
  }
}
